  IDVAR = pin;
  CLASSES = c(4);

  ANALYSIS:
  TYPE = MIXTURE;
  STARTS = 1000 250;
  K-1STARTS = 500 125;
  PROCESSORS = 8;

  MODEL:
  %OVERALL%
  i s q |
  SOFAS_0@0 SOFAS_12@12 SOFAS_24@24;
