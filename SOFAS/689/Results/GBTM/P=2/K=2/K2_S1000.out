INPUT INSTRUCTIONS

  TITLE:
  GBTM_P2_K2_S1000

  DATA:
  FILE = "/Users/olivierpercie/Desktop/LGM/SOFAS/689/Results/GBTM/P=2/K=2/K2_S1000.dat";

  VARIABLE:
  NAMES = pin SOFAS_0 SOFAS_12 SOFAS_24;
   MISSING=.;
   USEVAR = SOFAS_0 SOFAS_12 SOFAS_24;
  IDVAR = pin;
  CLASSES = c(2);

  ANALYSIS:
  TYPE = MIXTURE;
  STARTS = 1000 250;
  K-1STARTS = 500 125;
  PROCESSORS = 8;

  MODEL:
  %OVERALL%
  i s q |
  SOFAS_0@0 SOFAS_12@12 SOFAS_24@24;
  i-q@0;
  SOFAS_0-SOFAS_24 (1);
  %c#1%
  [i s q];
  %c#2%
  [i s q];

  OUTPUT:
  SAMPSTAT STANDARDIZED;
  TECH1;
  TECH11;

  SAVEDATA:
  FILE = K2_S1000_res.dat;
  SAVE = CPROBABILITIES FSCORES;

  PLOT:
  TYPE = plot3;
  SERIES = SOFAS_0 (s) SOFAS_12 (s) SOFAS_24 (s);




