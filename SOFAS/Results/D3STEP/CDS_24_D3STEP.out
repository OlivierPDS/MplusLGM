  [CDS_24](M2); CDS_24;
  MODEL CONSTRAINT:
  New (diff12);
  diff12 = M1 - M2;
  MODEL TEST:
  M1 = M2;
  OUTPUT:
  SAMPSTAT;
  STANDARDIZED;
  CINTERVAL;



