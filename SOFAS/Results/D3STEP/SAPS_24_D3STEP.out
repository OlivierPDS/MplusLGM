  VARIABLE:
  NAMES = PIN SOFAS_0 SOFAS_12 SOFAS_24 I S Q C_I C_S C_Q CPROB1 CPROB2 N SAPS_24;
   MISSING=.;
   USEVAR = SAPS_24 N;
  NOMINAL = N;
  CLASSES = c(2);
  ANALYSIS:
  TYPE = MIXTURE;
  STARTS = 0;
  PROCESSORS = 8;
  MODEL:
  %OVERALL%
  %C#1%
  [N#1@1.35];
  [SAPS_24](M1); SAPS_24;
  %C#2%
  [N#1@-1.788];
  [SAPS_24](M2); SAPS_24;
  MODEL CONSTRAINT:
  New (diff12 diff21);
  diff12 = M1 - M2;
  diff21 = M2 - M1;
  MODEL TEST:
  M1 = M2;
  OUTPUT:
  SAMPSTAT;
  STANDARDIZED;
  CINTERVAL;
  TECH7;
  TECH12;



