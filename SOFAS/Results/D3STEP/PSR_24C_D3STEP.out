  VARIABLE:
  NAMES = PIN SOFAS_0 SOFAS_12 SOFAS_24 I S Q C_I C_S C_Q CPROB1 CPROB2 N PSR_24C;
   MISSING=.;
   USEVAR = PSR_24C N;
  NOMINAL = N;
  CLASSES = c(2);
  ANALYSIS:
  TYPE = MIXTURE;
  STARTS = 0;
  PROCESSORS = 8;
  MODEL:
  %OVERALL%
  %C#1%
