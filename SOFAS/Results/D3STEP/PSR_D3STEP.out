  New (diff12 diff21);
  diff12 = M1 - M2;
  diff21 = M2 - M1;
  MODEL TEST:
  M1 = M2;
  OUTPUT:
  SAMPSTAT;
  STANDARDIZED;
  CINTERVAL;
  TECH7;
  TECH12;



