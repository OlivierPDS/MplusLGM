  DATA:
  FILE = "/Users/olivierpercie/Desktop/MplusLGM/SOFAS/Results/D3STEP/JSR_24C_D3STEP.dat";

  VARIABLE:
  NAMES = PIN SOFAS_0 SOFAS_12 SOFAS_24 I S Q C_I C_S C_Q CPROB1 CPROB2 N JSR_24C;
   MISSING=.;
   USEVAR = JSR_24C N;
  NOMINAL = N;
  CLASSES = c(2);
  ANALYSIS:
  TYPE = MIXTURE;
  STARTS = 2000;
  PROCESSORS = 8;
  MODEL:
  %OVERALL%
  %C#1%
  [N#1@2.417];
  [JSR_24C](M1); JSR_24C;
  %C#2%
  [N#1@-1.957];
  [JSR_24C](M2); JSR_24C;
  MODEL CONSTRAINT:
  New (diff12);
  diff12 = M1 - M2;
  MODEL TEST:
  M1 = M2;
  OUTPUT:
  TECH7;
  SAMPSTAT;
  STANDARDIZED;
  CINTERVAL;



