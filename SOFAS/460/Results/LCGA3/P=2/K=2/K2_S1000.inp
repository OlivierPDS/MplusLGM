%c#1%
[i s q];
SOFAS_0 (1)
SOFAS_12 (2)
SOFAS_24 (3)
%c#2%
[i s q];
SOFAS_0 (4)
SOFAS_12 (5)
SOFAS_24 (6)

OUTPUT:
