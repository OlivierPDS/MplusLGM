TITLE:
LCGA3_P2_K2_S1000

DATA:
FILE = "/Users/olivierpercie/Desktop/LGM/SOFAS/460/Results/LCGA3/P=2/K=2/K2_S1000.dat";
 
VARIABLE:
NAMES = pin SOFAS_0 SOFAS_12 SOFAS_24; 
 MISSING=.;
 USEVAR = SOFAS_0 SOFAS_12 SOFAS_24;
IDVAR = pin;
CLASSES = c(2);

ANALYSIS:
TYPE = MIXTURE;
STARTS = 1000 250;
K-1STARTS = 500 125;
