  DATA:
  FILE = "/Users/olivierpercie/Desktop/MplusLGM/SAPS/Results/D3STEP/D3STEP_YMRS_0.dat";

  VARIABLE:
  NAMES = PIN I S Q CUB C_I C_S C_Q C_CUB CPROB1 CPROB2 N YMRS_0;
   MISSING=.;
   USEVAR = YMRS_0 N;
  NOMINAL = N;
  CLASSES = c(2);
  ANALYSIS:

    TYPE = MIXTURE;
    STARTS = 0;
    PROCESSORS = 8;

  MODEL:
  %OVERALL%
  YMRS_0;

  %C#1%
