  i s q cub;
  i WITH s q cub;
  s WITH q cub;
  q WITH cub;
  SAPS_0 SAPS_1 SAPS_2 SAPS_3 SAPS_6 SAPS_9 SAPS_12 SAPS_18 SAPS_24 (1);
  %C#2%
  i s q cub;
  i WITH s q cub;
  s WITH q cub;
  q WITH cub;
  SAPS_0 SAPS_1 SAPS_2 SAPS_3 SAPS_6 SAPS_9 SAPS_12 SAPS_18 SAPS_24 (2);
  OUTPUT:
