  VARIABLE:
  NAMES = PIN I S Q CUB C_I C_S C_Q C_CUB CPROB1 CPROB2 CPROB3 N SANS_24;
   MISSING=.;
   USEVAR = SANS_24 N;
  NOMINAL = N;
  CLASSES = c(3);
  ANALYSIS:

    TYPE = MIXTURE;
    STARTS = 0;
    PROCESSORS = 8;

  MODEL:
  %OVERALL%
  SANS_24;

  %C#1%
  [N#1@3.075];
  [N#2@1.083];
  [SANS_24](M1); SANS_24;

  %C#2%
  [N#1@1.199];
  [N#2@2.945];
