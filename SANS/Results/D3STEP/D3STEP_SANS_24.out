  %C#3%
  [N#1@-1.281];
  [N#2@-1.148];
  [SANS_24](M3); SANS_24;
  MODEL CONSTRAINT:
  New (diff12 diff13 diff23);
  diff12 = M1 - M2;
  diff13 = M1 - M3;
  diff23 = M2 - M3;
  MODEL TEST:
  M1 = M2; M1 = M3; M2 = M3;



