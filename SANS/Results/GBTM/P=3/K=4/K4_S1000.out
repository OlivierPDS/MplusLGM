  SANS_0-SANS_24 (1);
  %c#1%
  [i s q cub];
  %c#2%
  [i s q cub];
  %c#3%
  [i s q cub];
  %c#4%
  [i s q cub];

  OUTPUT:
  sampstat standardized
  TECH1;
  TECH11;

  SAVEDATA:
  file = K4_S1000_res.dat;
  save = CPROBABILITIES;

  PLOT:
  TYPE = plot3;
  SERIES = SANS_0 (s) SANS_1 (s) SANS_2 (s) SANS_3 (s)
  SANS_6 (s) SANS_9 (s) SANS_12 (s) SANS_18 (s)
  SANS_24 (s);




