  K-1STARTS = 500 125;
  PROCESSORS = 8;

  MODEL:
  %OVERALL%
  i s q cub |
  SANS_b@0 SANS_1@1 SANS_2@2 SANS_3@3 SANS_6@6
  SANS_9@9 SANS_12@12 SANS_18@18 SANS_24@24;
