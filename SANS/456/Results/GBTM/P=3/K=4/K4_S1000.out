  STARTS = 1000 250;
  K-1STARTS = 500 125;
  PROCESSORS = 8;

  MODEL:
  %OVERALL%
  i s q cub |
  SANS_0@0 SANS_1@1 SANS_2@2 SANS_3@3 SANS_6@6
